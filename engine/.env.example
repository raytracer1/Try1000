# Backend URL
TRY1000_BACKEND_URL=

# Ably key for real-time task dispatch (optional — poll mode if unset)
TRY1000_ABLY_KEY=

# Poll mode (set to 1 for polling-only, 0 to use Ably push)
TRY1000_POLL=0

# Poll interval in seconds
TRY1000_POLL_INTERVAL=30

# LLM — set one of these for AI-generated strategies
# DASHSCOPE_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Supabase (for replay storage)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
