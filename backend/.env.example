# Local dev (SQLite — no setup needed)
DATABASE_URL=sqlite:///./try1000.db

# Production (Supabase / PostgreSQL)
# DATABASE_URL=postgresql://user:pass@host:5432/try1000

# JWT (change in production!)
TRY1000_JWT_SECRET_KEY=change-me-in-production

# LLM (optional — leave empty for Level 1 rule-based AI)
TRY1000_LLM_PROVIDER=anthropic
TRY1000_LLM_API_KEY=sk-ant-...
TRY1000_LLM_MODEL=claude-sonnet-5
